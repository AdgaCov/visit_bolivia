CREATE TABLE location_reviews (
    id INT AUTO_INCREMENT PRIMARY KEY,
    location_id INT NOT NULL,
    user_id INT,
    rating TINYINT CHECK (rating BETWEEN 1 AND 5),
    comment TEXT,
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    FOREIGN KEY (location_id) REFERENCES locations(id) ON DELETE CASCADE,
    FOREIGN KEY (user_id) REFERENCES users(id)
);
-- examen preocupacion de 8:30 a 10:15


CREATE TABLE location_services (
    id INT AUTO_INCREMENT PRIMARY KEY,
    location_id INT NOT NULL,
    
    name VARCHAR(150) NOT NULL,                  -- Service name
    description TEXT,                            -- Detailed description
    price DECIMAL(10,2) NULL,                    -- NULL if free
    type VARCHAR(100),                           -- General category (e.g., "Research")
    service_type ENUM(
        'library',
        'historical_archive',
        'map_collection',
        'conference_room',
        'souvenir_shop',
        'accessibility',
        'wifi',
        'parking',
        'guided_tour',
        'other'
    ),
    capacity INT NULL,                           -- People, items, etc.
    is_available BOOLEAN DEFAULT TRUE,
    image_url VARCHAR(500) NULL,                 -- Official image URL
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,
    
    FOREIGN KEY (location_id) REFERENCES locations(id) ON DELETE CASCADE,
    INDEX idx_location_services_location_id (location_id),
    INDEX idx_location_services_service_type (service_type)
);




CREATE TABLE location_items ( 
    id INT PRIMARY KEY AUTO_INCREMENT, 
    location_id INT NOT NULL, 
    name VARCHAR(255) NOT NULL, 
    description TEXT, 
    type ENUM('room', 'dish', 'service', 'offer', 'other') DEFAULT 'other', 
    price DECIMAL(10,2), 
    review VARCHAR(30),
    image_url VARCHAR(255), 
    CONSTRAINT fk_location_id FOREIGN KEY (location_id) REFERENCES locations(id) 
);




CREATE TABLE service ( 
    id INT PRIMARY KEY AUTO_INCREMENT, 
    name VARCHAR(100) NOT NULL, 
    icon VARCHAR(100), -- opcional, si usas íconos como "fa-wifi" o "fa-fire-extinguisher" 
    description TEXT 
);--Como un hotel puede tener muchos servicios y un mismo servicio puede aplicarse a varios lugares, se necesita una tabla intermedia: 
CREATE TABLE location_service ( 
    location_id INT NOT NULL, 
    service_id INT NOT NULL, 
    PRIMARY KEY (location_id, service_id), 
    FOREIGN KEY (location_id) REFERENCES location(id), 
    FOREIGN KEY (service_id) REFERENCES service(id) 
);

CREATE TABLE location_images (
    id INT AUTO_INCREMENT PRIMARY KEY,
    location_id INT NOT NULL,
    image_url VARCHAR(500) NOT NULL,
