CREATE TABLE `location_policies` (
  `id` INT PRIMARY KEY AUTO_INCREMENT,
  `location_id` INT NOT NULL,
  
  -- RESERVAS (útil para restaurantes, eventos, alojamientos)
  `reservation_recommended` TINYINT(1) DEFAULT 0,        -- 1 = sí se recomienda reservar
  `reservation_notes` VARCHAR(255) DEFAULT NULL,        -- ej: "Reservas recomendadas fines de semana"
  `reservation_link` VARCHAR(255) DEFAULT NULL,         -- enlace a sistema de reservas (opcional)

  -- CANCELACIÓN
  `cancellation_deadline_hours` INT DEFAULT NULL,       -- ej: 24 → "Hasta 24h antes"
  `cancellation_policy` TEXT DEFAULT NULL,              -- texto adicional si es compleja

  -- HORARIOS (muy relevante en restaurantes, eventos puntuales o recurrentes)
  `opening_hours` VARCHAR(100) DEFAULT NULL,            -- podría reemplazar el campo en `locations` si lo mueves aquí
  `days_closed` VARCHAR(50) DEFAULT NULL,               -- ej: "Lunes", o "Ninguno"

  -- FORMAS DE PAGO (crucial en restaurantes, eventos con entrada, alojamientos)
  `accepts_cash` TINYINT(1) DEFAULT 1,
  `accepts_credit_card` TINYINT(1) DEFAULT 0,
  `accepts_debit_card` TINYINT(1) DEFAULT 0,
  `accepts_bank_transfer` TINYINT(1) DEFAULT 0,
  `accepts_digital_wallet` TINYINT(1) DEFAULT 0,        -- Yape, Mercado Pago, etc.
  `payment_notes` VARCHAR(255) DEFAULT NULL,            -- ej: "Transferencia 24h antes del evento"

  -- ESPECÍFICO PARA EVENTOS
  `event_duration_hours` DECIMAL(5,2) DEFAULT NULL,     -- ej: 3.5 horas
  `minimum_age` INT DEFAULT NULL,                       -- si es un evento +18, etc.
  `dress_code` VARCHAR(100) DEFAULT NULL,               -- "Formal", "Casual", "Típico boliviano"

  -- AUDITORÍA
  `created_at` TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
  `updated_at` TIMESTAMP DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,

  -- RELACIÓN
  FOREIGN KEY (`location_id`) REFERENCES `locations`(`id`) ON DELETE CASCADE
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb3 COLLATE=utf8mb3_spanish2_ci;



