{
    "name": "conoce-bolivia/api",
    "description": "API REST para sistema de turismo Conoce Bolivia",
    "type": "project",
    "require": {
        "php": ">=8.0",
        "slim/slim": "^4.12",
        "slim/psr7": "^1.6",
        "php-di/php-di": "^7.0",
        "php-di/slim-bridge": "^3.4",
        "firebase/php-jwt": "^6.8",
        "vlucas/phpdotenv": "^5.5",
        "illuminate/database": "^10.0",
        "respect/validation": "^2.2",
        "nesbot/carbon": "^2.66"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "config": {
        "optimize-autoloader": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
